# 环境变量配置文件

# 应用配置
APP_NAME=Project Phoenix - AI短视频操作系统
APP_VERSION=1.0.0
DEBUG=true

# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/phoenix?charset=utf8mb4

# Redis配置
REDIS_URL=redis://localhost:6379/0

# 安全配置
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 存储配置
STORAGE_PATH=./storage
