# 环境变量配置文件（复制为 .env 后按需修改）

# ===== 应用配置 =====
APP_NAME=Project Phoenix - AI短视频操作系统
APP_VERSION=1.0.0
DEBUG=true

# ===== 数据库配置 =====
# 本地开发默认使用 SQLite，开箱即用
DATABASE_URL=sqlite:///./phoenix.db
# 生产环境示例（MySQL）：请另行创建库，并将上一行注释掉
# DATABASE_URL=mysql+pymysql://<user>:<password>@<host>:3306/phoenix?charset=utf8mb4

# ===== Redis 配置 =====
REDIS_URL=redis://localhost:6379/0

# ===== 安全配置 =====
# 生产必须替换为随机长字符串，不要提交真实值到仓库
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== 存储配置 =====
STORAGE_PATH=./storage

# ===== AI 配置 =====
# 默认 mock, 生产切 ark (火山方舟 Agent Plan, OpenAI 兼容 Responses API)
AI_PROVIDER=mock
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
# ARK_API_KEY=<your-ark-api-key>
# ARK_MODEL=ark-code-latest
# ARK_TIMEOUT=30
